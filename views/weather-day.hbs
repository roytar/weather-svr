<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>One-Day Weather</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <style>
      :root {
        --bg: #f4f7fb;
        --card: #ffffff;
        --ink: #1f2937;
        --subtle: #4b5563;
        --line: #dbe4ee;
        --accent: #0f766e;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 2rem 1rem;
        font-family: "Avenir Next", "Segoe UI", sans-serif;
        background: radial-gradient(circle at top left, #e8f9f6, var(--bg) 45%);
        color: var(--ink);
      }

      .wrap {
        max-width: 980px;
        margin: 0 auto;
      }

      .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(31, 41, 55, 0.08);
      }

      .header {
        padding: 1.5rem 1.8rem;
        border-bottom: 1px solid var(--line);
        background: linear-gradient(135deg, #edfaf7 0%, #f4f7fb 100%);
      }

      .header-top {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.4rem;
      }

      .header-top-left {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .current-time {
        font-size: 1rem;
        font-weight: 500;
        color: var(--accent);
      }

      .day {
        font-size: 1.35rem;
        font-weight: 700;
      }

      .header-location {
        font-size: 0.88rem;
        color: var(--subtle);
      }

      .header-controls {
        display: flex;
        align-items: flex-start;
        gap: 0.6rem;
      }

      .address-form {
        margin: 0;
        display: flex;
      }

      .address-combobox {
        position: relative;
        display: flex;
        align-items: center;
      }

      .address-input {
        height: 2.25rem;
        padding: 0.5rem 0.75rem;
        padding-right: 2.2rem;
        border: 1px solid var(--line);
        border-radius: 0.375rem;
        background: var(--card);
        color: var(--ink);
        font-size: 0.88rem;
        min-width: 360px;
        transition: border-color 0.2s ease, background-color 0.2s ease;
      }

      .address-input::placeholder {
        color: var(--subtle);
        opacity: 0.7;
      }

      .address-input:hover {
        border-color: var(--accent);
        background-color: #f9fdfb;
      }

      .address-input:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 2px rgba(15, 118, 110, 0.1);
      }

      .address-toggle {
        position: absolute;
        right: 0.35rem;
        border: 0;
        background: transparent;
        color: var(--subtle);
        font-size: 0.9rem;
        cursor: pointer;
        line-height: 1;
        padding: 0.2rem;
      }

      .address-menu {
        position: absolute;
        top: calc(100% + 0.2rem);
        left: 0;
        right: 0;
        list-style: none;
        margin: 0;
        padding: 0.25rem 0;
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 0.375rem;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
        max-height: 240px;
        overflow-y: auto;
        z-index: 20;
        display: none;
      }

      .address-menu.open {
        display: block;
      }

      .address-menu-item {
        width: 100%;
        border: 0;
        background: transparent;
        text-align: left;
        padding: 0.45rem 0.75rem;
        font-size: 0.88rem;
        color: var(--ink);
        cursor: pointer;
      }

      .address-menu-item:hover {
        background: #eef9f6;
      }

      .address-menu-empty {
        padding: 0.45rem 0.75rem;
        font-size: 0.84rem;
        color: var(--subtle);
      }

      .date-form {
        display: flex;
        margin: 0;
      }

      .date-input {
        height: 2.25rem;
        padding: 0.5rem 0.75rem;
        border: 1px solid var(--line);
        border-radius: 0.375rem;
        background: var(--card);
        color: var(--ink);
        font-size: 0.88rem;
        transition: border-color 0.2s ease, background-color 0.2s ease;
      }

      .date-input:hover {
        border-color: var(--accent);
        background-color: #f9fdfb;
      }

      .date-input:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 2px rgba(15, 118, 110, 0.1);
      }

      .header-body {
        display: flex;
        align-items: center;
        gap: 1.4rem;
        margin-top: 1rem;
      }

      .weather-icon {
        width: 100px;
        height: 100px;
        flex: 0 0 auto;
        filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.18));
        transition: transform 0.25s ease;
      }

      .weather-icon:hover {
        transform: scale(1.08);
      }

      .temp-main {
        font-size: 3.6rem;
        font-weight: 700;
        line-height: 1;
        color: var(--ink);
      }

      .temp-unit {
        font-size: 1.6rem;
        font-weight: 400;
        vertical-align: super;
      }

      .condition-block {
        flex: 1;
      }

      .condition-label {
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--accent);
      }

      .hi-lo {
        margin-top: 0.3rem;
        font-size: 0.92rem;
        color: var(--subtle);
      }

      .stats-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem 1.6rem;
        margin-top: 1rem;
        padding-top: 0.85rem;
        border-top: 1px solid var(--line);
        font-size: 0.88rem;
        color: var(--subtle);
      }

      .stat {
        display: flex;
        align-items: center;
        gap: 0.3rem;
      }

      .stat strong {
        color: var(--ink);
      }

      @media (max-width: 600px) {
        .header-body {
          flex-wrap: wrap;
        }

        .temp-main {
          font-size: 2.8rem;
        }
      }

      .hour-icon {
        width: 40px;
        height: 40px;
        display: block;
        filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.15));
        transition: transform 0.2s ease;
      }

      .expandable:hover .hour-icon {
        transform: scale(1.15);
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      thead th {
        text-align: right;
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--subtle);
        background: #f9fbfd;
      }

      thead th:first-child,
      thead th:nth-child(2),
      thead th:nth-child(3) {
        text-align: left;
      }

      th,
      td {
        padding: 0.7rem 1rem;
        border-bottom: 1px solid var(--line);
        white-space: nowrap;
      }

      td:not(:first-child):not(:nth-child(2)):not(:nth-child(3)) {
        text-align: right;
        font-variant-numeric: tabular-nums;
      }

      tbody tr:hover {
        background: #f7fafc;
      }

      tbody tr:last-child td {
        border-bottom: 0;
      }

      @media (max-width: 720px) {
        .header {
          padding: 1rem;
        }

        th,
        td {
          padding: 0.6rem 0.5rem;
          font-size: 0.86rem;
        }
      }

      .expandable {
        cursor: pointer;
      }

      .expandable:hover {
        background: #eef4fb;
      }

      .caret {
        display: inline-block;
        font-size: 0.72rem;
        color: var(--accent);
        transition: transform 0.15s ease;
        user-select: none;
      }

      .caret.open {
        transform: rotate(90deg);
      }

      .minutely-detail > td {
        padding: 0;
        background: #f4f8ff;
      }

      .minutely-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.82rem;
      }

      .minutely-table th,
      .minutely-table td {
        padding: 0.4rem 0.85rem;
        border-bottom: 1px solid #e5ecf4;
        color: var(--subtle);
        white-space: nowrap;
      }

      .minutely-table thead th {
        background: #e8f0fe;
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.02em;
      }

      .minutely-table tbody tr:last-child td {
        border-bottom: 0;
      }

      /* ── Custom tooltips ───────────────────────────────────────── */
      .icon-wrap {
        display: inline-block;
        line-height: 0;
      }

      [data-tooltip] {
        position: relative;
      }

      [data-tooltip]::after {
        content: attr(data-tooltip);
        position: absolute;
        bottom: calc(100% + 6px);
        left: 50%;
        transform: translateX(-50%);
        background: #1f2937;
        color: #f9fafb;
        font-size: 0.75rem;
        font-weight: 400;
        line-height: 1.4;
        padding: 0.3rem 0.55rem;
        border-radius: 5px;
        white-space: nowrap;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.15s ease;
        z-index: 100;
        max-width: 240px;
        white-space: normal;
        text-align: center;
      }

      [data-tooltip]::before {
        content: "";
        position: absolute;
        bottom: calc(100% + 2px);
        left: 50%;
        transform: translateX(-50%);
        border: 4px solid transparent;
        border-top-color: #1f2937;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.15s ease;
        z-index: 100;
      }

      [data-tooltip]:hover::after,
      [data-tooltip]:hover::before {
        opacity: 1;
      }
    </style>
  </head>
  <body>
    <script>
      // Make page data available to JavaScript
      window.__pageData = {
        wasZipCodeOnly: {{wasZipCodeOnly}},
        expandedAddress: "{{expandedAddress}}"
      };
    </script>
    <script>
      // Convert title attributes to data-tooltip for custom styled tooltips.
      // Skip form controls where native title is used for browser hints.
      document.addEventListener("DOMContentLoaded", () => {
        const skip = new Set(["INPUT", "TEXTAREA", "SELECT", "BUTTON"]);
        document.querySelectorAll("[title]").forEach((el) => {
          if (skip.has(el.tagName)) return;
          el.dataset.tooltip = el.getAttribute("title");
          el.removeAttribute("title");
        });
      });
    </script>
    <main class="wrap">
      <section class="card">
        <header class="header">
          <div class="header-top">
            <div class="header-top-left">
              <div class="day">
                {{dayDate}}
                {{#if isHistoric}}
                  <span style="color: var(--accent); font-size: 0.85rem; margin-left: 0.5rem; font-weight: 500;">Historic</span>
                {{else}}
                  {{#if isForecast}}
                    <span style="color: var(--accent); font-size: 0.85rem; margin-left: 0.5rem; font-weight: 500;">Forcast</span>
                  {{/if}}
                {{/if}}
              </div>
              {{#unless isViewingForecast}}
                <div class="current-time">{{currentTime}}</div>
              {{/unless}}
              <div class="header-controls">
                <form id="addressForm" class="address-form">
                  <div class="address-combobox">
                    <input
                      type="text"
                      id="addressInput"
                      class="address-input"
                      placeholder="📍 Enter address..."
                      autocomplete="off"
                      title="Type or choose a recent address"
                    />
                    <button
                      type="button"
                      id="addressToggle"
                      class="address-toggle"
                      title="Show recent addresses"
                      aria-label="Show recent addresses"
                    >
                      ▼
                    </button>
                    <ul id="addressMenu" class="address-menu"></ul>
                  </div>
                </form>
                <form id="dateForm" class="date-form">
                  <input
                    type="date"
                    id="dateInput"
                    class="date-input"
                    title="Select a date"
                  />
                </form>
                <script>
                  // Constrain date input max to ~15 days in future (API limit).
                  const dateInput = document.getElementById('dateInput');
                  const today = new Date();
                  const maxDate = new Date(today);
                  maxDate.setDate(maxDate.getDate() + 15);
                  const maxDateStr = maxDate.toISOString().split('T')[0];
                  dateInput.max = maxDateStr;
                </script>
              </div>
            </div>
            <div class="header-location">🌍&nbsp;{{timezone}}</div>
          </div>
          <div class="header-body">
            <span class="icon-wrap" title="{{summary}} (code: {{iconCode}})">
              <img
                class="weather-icon"
                src="{{meteoconUrl}}"
                alt="{{summary}}"
                width="100"
                height="100"
              />
            </span>
            {{#unless isViewingForecast}}
              <div class="temp-main">{{currentTemp}}<span class="temp-unit">°F</span></div>
            {{/unless}}
            <div class="condition-block">
              <div class="condition-label" title="Current weather condition">{{summary}}</div>
              <div class="hi-lo">
                <span title="Today's high temperature">H:&nbsp;<strong>{{highTemp}}°</strong></span>&nbsp;&nbsp;
                <span title="Today's low temperature">L:&nbsp;<strong>{{lowTemp}}°</strong></span>&nbsp;&nbsp;
                <span title="Maximum apparent temperature today (feels like)">Feels like max:&nbsp;<strong>{{apparentTempMax}}°</strong></span>
              </div>
            </div>
          </div>
          <div class="stats-row">
            {{#unless isViewingForecast}}
              <div class="stat" title="Current wind speed and direction">💨&nbsp;<strong>{{currentWindSpeed}} mph</strong>&nbsp;{{currentWindDir}}&nbsp;({{currentWindDeg}}°)</div>
              <div class="stat" title="Current precipitation">🌧&nbsp;<strong>{{currentPrecip}} in</strong>&nbsp;now</div>
              <div class="stat" title="Current relative humidity">💧&nbsp;<strong>{{relativeHumidity}}%</strong>&nbsp;humidity</div>
            {{/unless}}
            <div class="stat" title="Maximum wind speed today">🌬&nbsp;Max wind:&nbsp;<strong>{{maxWindSpeed}} mph</strong></div>
            <div class="stat" title="Maximum wind gusts today">💨&nbsp;Gusts:&nbsp;<strong>{{maxGusts}} mph</strong></div>
          </div>
          <div class="stats-row">
            <div class="stat" title="Sunrise time today">🌅&nbsp;<strong>{{sunriseTime}}</strong></div>
            <div class="stat" title="Sunset time today">🌇&nbsp;<strong>{{sunsetTime}}</strong></div>
          </div>
        </header>

        <table>
          <thead>
            <tr>
              <th title="Expand/collapse 15-minute forecast"></th>
              <th title="Weather icon and condition">Icon</th>
              <th title="Hour of day (24-hour format)">Hour</th>
              <th title="Temperature in Fahrenheit">Temp (F)</th>
              <th title="Wind speed in miles per hour">Wind (mph)</th>
              <th title="Wind direction (cardinal and degrees)">Direction</th>
              <th title="Total precipitation including rain, snow, and sleet">Precip (in)</th>
              <th title="Rainfall only">Rain (in)</th>
              <th title="Snowfall only">Snow (in)</th>
            </tr>
          </thead>
          <tbody>
            {{#each hourlyRows}}
              <tr
                class="{{#if this.hasMinutely15}}expandable{{/if}}"
                {{#if this.hasMinutely15}}onclick="toggleMinutely({{@index}})"{{/if}}
              >
                <td>
                  {{#if this.hasMinutely15}}
                    <span class="caret" id="caret-{{@index}}">&#9654;</span>
                  {{/if}}
                </td>
                <td>
                  <span class="icon-wrap" title="{{this.iconSummary}} (code: {{this.iconCode}})">
                    <img
                      class="hour-icon"
                      src="{{this.meteoconUrl}}"
                      alt="{{this.iconSummary}}"
                      width="40"
                      height="40"
                    />
                  </span>
                </td>
                <td>{{this.hour}}</td>
                <td>{{this.temperature}}</td>
                <td>{{this.windSpeed}}</td>
                <td>{{this.windDirectionCardinal}}
                  ({{this.windDirectionDegrees}}&deg;)</td>
                <td>{{this.precipitation}}</td>
                <td>{{this.rain}}</td>
                <td>{{this.snow}}</td>
              </tr>
              {{#if this.hasMinutely15}}
                <tr class="minutely-detail" id="m15-{{@index}}" style="display:none">
                  <td colspan="9">
                    <table class="minutely-table">
                      <thead>
                        <tr>
                          <th title="15-minute interval time">Time</th>
                          <th title="Air temperature in Fahrenheit">Temp (°F)</th>
                          <th title="Rainfall accumulation in inches">Rain (in)</th>
                          <th title="Horizontal visibility in meters">Visibility (m)</th>
                          <th title="Duration of direct sunshine in seconds">Sunshine (s)</th>
                        </tr>
                      </thead>
                      <tbody>
                        {{#each this.minutely15}}
                          <tr>
                            <td>{{this.time}}</td>
                            <td title="Temperature at {{this.time}}">{{this.temperature}}</td>
                            <td title="Rain at {{this.time}}">{{this.rain}}</td>
                            <td title="Visibility at {{this.time}}">{{this.visibility}}</td>
                            <td title="Sunshine duration at {{this.time}}">{{this.sunshine_duration}}</td>
                          </tr>
                        {{/each}}
                      </tbody>
                    </table>
                  </td>
                </tr>
              {{/if}}
            {{/each}}
          </tbody>
        </table>
      </section>
    </main>
  <script>
    function toggleMinutely(idx) {
      const detail = document.getElementById('m15-' + idx);
      const caret = document.getElementById('caret-' + idx);
      const isOpen = detail.style.display !== 'none';
      detail.style.display = isOpen ? 'none' : 'table-row';
      caret.classList.toggle('open', !isOpen);
    }

    // Address history management with input field
    (function initAddressHistory() {
      const form = document.getElementById('addressForm');
      const input = document.getElementById('addressInput');
      const menu = document.getElementById('addressMenu');
      const toggle = document.getElementById('addressToggle');
      const STORAGE_KEY = 'weatherAddressHistory';
      const MAX_HISTORY = 10;

      // Get current address from URL parameters
      function getCurrentAddress() {
        const params = new URLSearchParams(window.location.search);
        return params.get('address') || '';
      }

      // Load history from localStorage
      function loadHistory() {
        const stored = localStorage.getItem(STORAGE_KEY);
        return stored ? JSON.parse(stored) : [];
      }

      // Save history to localStorage
      function saveHistory(history) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(history));
      }

      // Add address to history and trim to MAX_HISTORY
      function addToHistory(address) {
        if (!address || address.trim() === '') return;

        let history = loadHistory();
        // Remove if already exists
        history = history.filter(addr => addr !== address);
        // Add to front
        history.unshift(address);
        // Keep only last MAX_HISTORY
        history = history.slice(0, MAX_HISTORY);
        saveHistory(history);
        return history;
      }

      function navigateToAddress(address) {
        addToHistory(address);
        const url = new URL(window.location);
        url.searchParams.set('address', address);
        window.location.href = url.toString();
      }

      function renderMenu(filterText = '') {
        const normalizedFilter = filterText.trim().toLowerCase();
        const history = loadHistory().filter((addr) =>
          addr.toLowerCase().includes(normalizedFilter),
        );

        menu.innerHTML = '';

        if (history.length === 0) {
          const empty = document.createElement('li');
          empty.className = 'address-menu-empty';
          empty.textContent = 'No prior addresses';
          menu.appendChild(empty);
          return;
        }

        history.forEach((address) => {
          const row = document.createElement('li');
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'address-menu-item';
          btn.textContent = address;
          btn.addEventListener('click', function () {
            input.value = address;
            menu.classList.remove('open');
            navigateToAddress(address);
          });
          row.appendChild(btn);
          menu.appendChild(row);
        });
      }

      function openMenu() {
        renderMenu(input.value);
        menu.classList.add('open');
      }

      function closeMenu() {
        menu.classList.remove('open');
      }

      toggle.addEventListener('click', function () {
        if (menu.classList.contains('open')) {
          closeMenu();
          return;
        }
        openMenu();
        input.focus();
      });

      input.addEventListener('input', function () {
        openMenu();
      });

      input.addEventListener('focus', function () {
        renderMenu(input.value);
      });

      document.addEventListener('click', function (e) {
        if (!form.contains(e.target)) {
          closeMenu();
        }
      });

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        const address = input.value.trim();
        if (address) {
          closeMenu();
          navigateToAddress(address);
        }
      });

      // Initialize on page load
      const currentAddress = getCurrentAddress();
      if (currentAddress) {
        addToHistory(currentAddress);
        // If zip code only, show the expanded address in the input
        const displayAddress = (window.__pageData && window.__pageData.wasZipCodeOnly) 
          ? window.__pageData.expandedAddress
          : currentAddress;
        input.value = displayAddress;
      }
      renderMenu();
      closeMenu();
    })();

    // Date picker management
    (function initDatePicker() {
      const dateForm = document.getElementById('dateForm');
      const dateInput = document.getElementById('dateInput');

      // Get date from URL or default to today
      function getDateFromURL() {
        const params = new URLSearchParams(window.location.search);
        return params.get('date') || '';
      }

      // Format date to YYYY-MM-DD
      function formatDate(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
      }

      // Handle date change
      dateInput.addEventListener('change', function(e) {
        const selectedDate = e.target.value;
        if (selectedDate) {
          // Navigate with new date
          const url = new URL(window.location);
          url.searchParams.set('date', selectedDate);
          window.location.href = url.toString();
        }
      });

      // Initialize date input
      const urlDate = getDateFromURL();
      const displayDate = urlDate || formatDate(new Date());
      dateInput.value = displayDate;
    })();
  </script>
  </body>
</html>