<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Weather Explorer</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <style>
      :root {
        --bg: #f4f7fb;
        --card: #ffffff;
        --ink: #1f2937;
        --subtle: #4b5563;
        --line: #dbe4ee;
        --accent: #0f766e;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 2rem 1rem;
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
          Arial, sans-serif;
        background: radial-gradient(circle at top left, #e8f9f6, var(--bg) 45%);
        color: var(--ink);
      }

      .wrap {
        max-width: 980px;
        margin: 0 auto;
      }

      .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(31, 41, 55, 0.08);
      }

      .header {
        padding: 1.5rem 1.8rem;
        border-bottom: 1px solid var(--line);
        background: linear-gradient(135deg, #edfaf7 0%, #f4f7fb 100%);
      }

      .header-top {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.4rem;
      }

      .header-top-left {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .current-time {
        font-size: 1rem;
        font-weight: 500;
        color: var(--accent);
      }

      .header-meta {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        text-align: right;
        gap: 0.15rem;
        font-size: 0.88rem;
        color: var(--subtle);
      }

      .day {
        font-size: 1.35rem;
        font-weight: 700;
      }

      .date-status-badge {
        color: var(--accent);
        font-size: 0.85rem;
        margin-left: 0.5rem;
        font-weight: 500;
      }

      .date-status-badge:empty {
        display: none;
      }

      .header-location {
        font-size: 0.88rem;
        color: var(--subtle);
      }

      .header-body {
        display: flex;
        align-items: center;
        gap: 1.4rem;
        margin-top: 1rem;
      }

      .weather-icon {
        width: 100px;
        height: 100px;
        flex: 0 0 auto;
        filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.18));
        transition: transform 0.25s ease;
      }

      .weather-icon:hover {
        transform: scale(1.08);
      }

      .temp-main {
        font-size: 3.6rem;
        font-weight: 700;
        line-height: 1;
        color: var(--ink);
      }

      .temp-unit {
        font-size: 1.6rem;
        font-weight: 400;
        vertical-align: super;
      }

      .condition-block {
        flex: 1;
      }

      .condition-label {
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--accent);
      }

      .hi-lo {
        margin-top: 0.3rem;
        font-size: 0.92rem;
        color: var(--subtle);
      }

      .stats-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem 1.6rem;
        margin-top: 1rem;
        padding-top: 0.85rem;
        border-top: 1px solid var(--line);
        font-size: 0.88rem;
        color: var(--subtle);
      }

      .stat {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        min-width: 0;
      }

      .stat strong {
        color: var(--ink);
      }

      .table-shell {
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      .table-shell > table {
        min-width: 760px;
      }

      @media (max-width: 900px) {
        body {
          padding: 1rem 0.75rem;
        }

        .header-top {
          align-items: flex-start;
        }

        .header-top-left,
        .header-meta {
          width: 100%;
        }

        .header-body {
          flex-wrap: wrap;
          align-items: flex-start;
          gap: 1rem;
        }

        .condition-block {
          width: 100%;
          min-width: 0;
        }

        .hi-lo {
          line-height: 1.5;
          white-space: normal;
        }

        .stats-row {
          display: grid;
          grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
          gap: 0.65rem 1rem;
        }
      }

      @media (max-width: 600px) {
        .card {
          border-radius: 12px;
        }

        .header-body {
          flex-wrap: wrap;
        }

        .day {
          font-size: 1.15rem;
        }

        .current-time {
          font-size: 0.92rem;
        }

        .weather-icon {
          width: 80px;
          height: 80px;
        }

        .temp-main {
          font-size: 2.8rem;
        }

        .table-shell > table {
          min-width: 680px;
        }
      }

      .hour-icon {
        width: 40px;
        height: 40px;
        display: block;
        filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.15));
        transition: transform 0.2s ease;
      }

      .expandable:hover .hour-icon {
        transform: scale(1.15);
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      thead th {
        text-align: right;
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--subtle);
        background: #f9fbfd;
      }

      thead th:first-child,
      thead th:nth-child(2),
      thead th:nth-child(3) {
        text-align: left;
      }

      th,
      td {
        padding: 0.7rem 1rem;
        border-bottom: 1px solid var(--line);
        white-space: nowrap;
      }

      td:not(:first-child):not(:nth-child(2)):not(:nth-child(3)) {
        text-align: right;
        font-variant-numeric: tabular-nums;
      }

      tbody tr:hover {
        background: #f7fafc;
      }

      tbody tr:last-child td {
        border-bottom: 0;
      }

      @media (max-width: 720px) {
        .header {
          padding: 1rem;
        }

        th,
        td {
          padding: 0.6rem 0.5rem;
          font-size: 0.86rem;
        }
      }

      .expandable {
        cursor: pointer;
      }

      .expandable:hover {
        background: #eef4fb;
      }

      .caret {
        display: inline-block;
        font-size: 0.72rem;
        color: var(--accent);
        transition: transform 0.15s ease;
        user-select: none;
      }

      .caret.open {
        transform: rotate(90deg);
      }

      .minutely-detail > td {
        padding: 0;
        background: #f4f8ff;
      }

      .minutely-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.82rem;
      }

      .minutely-table th,
      .minutely-table td {
        padding: 0.4rem 0.85rem;
        border-bottom: 1px solid #e5ecf4;
        color: var(--subtle);
        white-space: nowrap;
      }

      .minutely-table thead th {
        background: #e8f0fe;
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.02em;
      }

      .minutely-table tbody tr:last-child td {
        border-bottom: 0;
      }

      /* ── Custom tooltips ───────────────────────────────────────── */
      .icon-wrap {
        display: inline-block;
        line-height: 0;
      }

      [data-tooltip] {
        position: relative;
      }

      [data-tooltip]::after {
        content: attr(data-tooltip);
        position: absolute;
        bottom: calc(100% + 6px);
        left: 50%;
        transform: translateX(-50%);
        background: #1f2937;
        color: #f9fafb;
        font-size: 0.75rem;
        font-weight: 400;
        line-height: 1.4;
        padding: 0.3rem 0.55rem;
        border-radius: 5px;
        white-space: nowrap;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.15s ease;
        z-index: 100;
        max-width: 240px;
        white-space: normal;
        text-align: center;
      }

      [data-tooltip]::before {
        content: "";
        position: absolute;
        bottom: calc(100% + 2px);
        left: 50%;
        transform: translateX(-50%);
        border: 4px solid transparent;
        border-top-color: #1f2937;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.15s ease;
        z-index: 100;
      }

      [data-tooltip]:hover::after,
      [data-tooltip]:hover::before {
        opacity: 1;
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <section class="card">
        <header class="header">
          <div class="header-top">
            <div class="header-top-left">
              <div>
                <div class="day">
                  {{dayDate}}
                  <span id="dateStatusBadge" class="date-status-badge">{{#if isHistoric}}Historic{{else}}{{#if isForecast}}Forecast{{/if}}{{/if}}</span>
                </div>
                <div class="header-location">
                  <div>{{streetLine}}</div>
                  {{#if localityLine}}
                    <div>{{localityLine}}</div>
                  {{/if}}
                  {{#if countryLine}}
                    <div>{{countryLine}}</div>
                  {{/if}}
                  <div>{{coordinatesLine}}</div>
                </div>
              </div>
            </div>
            <div class="header-meta">
              <div>🌍&nbsp;{{timezone}}</div>
              {{#unless isViewingForecast}}
                <div class="current-time">{{currentTime}}</div>
              {{/unless}}
            </div>
          </div>
          <div class="header-body">
            <span class="icon-wrap" title="{{summary}} (code: {{iconCode}})">
              <img
                class="weather-icon"
                src="{{meteoconUrl}}"
                alt="{{summary}}"
                width="100"
                height="100"
              />
            </span>
            {{#unless isViewingForecast}}
              <div class="temp-main">{{currentTemp}}<span class="temp-unit">°{{temperatureUnitLabel}}</span></div>
            {{/unless}}
            <div class="condition-block">
              <div class="condition-label" title="Current weather condition">{{summary}}</div>
              <div class="hi-lo">
                <span title="Today's high temperature">H:&nbsp;<strong>{{highTemp}}°</strong></span>&nbsp;&nbsp;
                <span title="Today's low temperature">L:&nbsp;<strong>{{lowTemp}}°</strong></span>&nbsp;&nbsp;
                <span title="Maximum apparent temperature today (feels like)">Feels like max:&nbsp;<strong>{{apparentTempMax}}°</strong></span>
              </div>
            </div>
          </div>
          <div class="stats-row">
            {{#unless isViewingForecast}}
              <div class="stat" title="Current wind speed and direction">💨&nbsp;<strong>{{currentWindSpeed}} {{windSpeedUnitLabel}}</strong>&nbsp;{{currentWindDir}}&nbsp;({{currentWindDeg}}°)</div>
              <div class="stat" title="Current precipitation">🌧&nbsp;<strong>{{currentPrecip}} {{precipitationUnitLabel}}</strong>&nbsp;now</div>
              <div class="stat" title="Current relative humidity">💧&nbsp;<strong>{{relativeHumidity}}%</strong>&nbsp;humidity</div>
            {{/unless}}
            <div class="stat" title="Maximum wind speed today">🌬&nbsp;Max wind:&nbsp;<strong>{{maxWindSpeed}} {{windSpeedUnitLabel}}</strong></div>
            <div class="stat" title="Maximum wind gusts today">💨&nbsp;Gusts:&nbsp;<strong>{{maxGusts}} {{windSpeedUnitLabel}}</strong></div>
            <div class="stat" title="Maximum precipitation probability for the selected day">☔&nbsp;Precip chance:&nbsp;<strong>{{precipitationProbabilityMax}}%</strong></div>
          </div>
          <div class="stats-row">
            <div class="stat" title="Sunrise time today">🌅&nbsp;<strong>{{sunriseTime}}</strong></div>
            <div class="stat" title="Sunset time today">🌇&nbsp;<strong>{{sunsetTime}}</strong></div>
          </div>
        </header>

        <div class="table-shell">
        <table>
          <thead>
            <tr>
              <th title="Expand/collapse 15-minute forecast"></th>
              <th title="Weather icon and condition">Icon</th>
              <th title="Hour of day (24-hour format)">Hour</th>
              <th title="Temperature for the selected unit system">Temp ({{temperatureUnitLabel}})</th>
              <th title="Probability of precipitation during the hour">Precip (%)</th>
              <th title="Total precipitation including rain, snow, and sleet">Precip ({{precipitationUnitLabel}})</th>
              <th title="Wind speed for the selected unit system">Wind ({{windSpeedUnitLabel}})</th>
              <th title="Wind direction (cardinal and degrees)">Direction</th>
              <th title="Rainfall only">Rain ({{precipitationUnitLabel}})</th>
              {{#if showSnowfall}}
                <th title="Snowfall only">Snow ({{precipitationUnitLabel}})</th>
              {{/if}}
            </tr>
          </thead>
          <tbody>
            {{#each hourlyRows}}
              <tr
                class="{{#if this.hasMinutely15}}expandable{{/if}}"
                {{#if this.hasMinutely15}}data-minutely-toggle="{{@index}}"{{/if}}
              >
                <td>
                  {{#if this.hasMinutely15}}
                    <span class="caret" id="caret-{{@index}}">&#9654;</span>
                  {{/if}}
                </td>
                <td>
                  <span class="icon-wrap" title="{{this.iconSummary}} (code: {{this.iconCode}})">
                    <img
                      class="hour-icon"
                      src="{{this.meteoconUrl}}"
                      alt="{{this.iconSummary}}"
                      width="40"
                      height="40"
                    />
                  </span>
                </td>
                <td>{{this.hour}}</td>
                <td>{{this.temperature}}</td>
                <td>{{this.precipitationProbability}}%</td>
                <td>{{this.precipitation}}</td>
                <td>{{this.windSpeed}}</td>
                <td>{{this.windDirectionCardinal}}
                  ({{this.windDirectionDegrees}}&deg;)</td>
                <td>{{this.rain}}</td>
                {{#if ../showSnowfall}}
                  <td>{{this.snow}}</td>
                {{/if}}
              </tr>
              {{#if this.hasMinutely15}}
                <tr class="minutely-detail" id="m15-{{@index}}" style="display:none">
                  <td colspan="{{#if ../showSnowfall}}10{{else}}9{{/if}}">
                    <table class="minutely-table">
                      <thead>
                        <tr>
                          <th title="15-minute interval time">Time</th>
                          <th title="Air temperature for the selected unit system">Temp (°{{temperatureUnitLabel}})</th>
                          <th title="Rainfall accumulation for the selected unit system">Rain ({{precipitationUnitLabel}})</th>
                          <th title="Horizontal visibility for the selected unit system">Visibility ({{visibilityUnitLabel}})</th>
                          <th title="Duration of direct sunshine in seconds">Sunshine (s)</th>
                        </tr>
                      </thead>
                      <tbody>
                        {{#each this.minutely15}}
                          <tr>
                            <td>{{this.time}}</td>
                            <td title="Temperature at {{this.time}}">{{this.temperature}}</td>
                            <td title="Rain at {{this.time}}">{{this.rain}}</td>
                            <td title="Visibility at {{this.time}}">{{this.visibility}}</td>
                            <td title="Sunshine duration at {{this.time}}">{{this.sunshine_duration}}</td>
                          </tr>
                        {{/each}}
                      </tbody>
                    </table>
                  </td>
                </tr>
              {{/if}}
            {{/each}}
          </tbody>
        </table>
        </div>
      </section>
    </main>
    <script src="/assets/weather-day.js" defer></script>
  </body>
</html>