<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Weather Explorer • Date Range</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <style>
      :root {
        --bg: #f4f7fb;
        --card: #ffffff;
        --ink: #1f2937;
        --subtle: #4b5563;
        --line: #dbe4ee;
        --accent: #0f766e;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        padding: 1.5rem;
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
          Arial, sans-serif;
        background: radial-gradient(circle at top left, #e8f9f6, var(--bg) 45%);
        color: var(--ink);
      }

      .shell {
        max-width: 900px;
        margin: 0 auto;
      }

      .hero {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(31, 41, 55, 0.08);
        padding: 1.5rem;
      }

      h1 {
        margin: 0.4rem 0 0.35rem;
        font-size: clamp(2rem, 5vw, 2.8rem);
      }

      .weather-title {
        display: inline-block;
        position: relative;
        overflow: hidden;
        padding: 0.35rem 0.8rem;
        border-radius: 0.9rem;
        font-weight: 900;
        letter-spacing: 0.02em;
        color: #0f172a;
        background:
          radial-gradient(
            circle at 18% 35%,
            rgba(253, 224, 71, 0.95) 0 10%,
            rgba(251, 191, 36, 0.9) 10% 18%,
            transparent 19%
          ),
          linear-gradient(
            115deg,
            rgba(255, 244, 178, 0.95) 0%,
            rgba(186, 230, 253, 0.9) 45%,
            rgba(96, 165, 250, 0.88) 70%,
            rgba(51, 65, 85, 0.92) 100%
          );
        box-shadow: 0 10px 24px rgba(15, 118, 110, 0.12);
      }

      .weather-title::after {
        content: "";
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          105deg,
          transparent 0 16px,
          rgba(255, 255, 255, 0.42) 16px 18px,
          transparent 18px 28px
        );
        opacity: 0.45;
        pointer-events: none;
      }

      .weather-title span {
        position: relative;
        z-index: 1;
      }

      .subtitle {
        margin: 0 0 1.25rem;
        color: var(--subtle);
        line-height: 1.5;
      }

      .search-form {
        display: grid;
        gap: 1rem;
      }

      .field-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 1rem;
      }

      .field {
        display: grid;
        gap: 0.35rem;
      }

      .field label,
      .legend {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--ink);
      }

      .field input {
        width: 100%;
        height: 2.6rem;
        padding: 0.55rem 0.8rem;
        border: 1px solid var(--line);
        border-radius: 0.5rem;
        background: var(--card);
        color: var(--ink);
        font-size: 0.95rem;
      }

      .field input:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(15, 118, 110, 0.12);
      }

      .field input.shake {
        border-color: #dc2626;
        box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.16);
        animation: input-shake 360ms cubic-bezier(0.36, 0.07, 0.19, 0.97);
      }

      @keyframes input-shake {
        0% {
          transform: translateX(0);
        }
        20% {
          transform: translateX(-6px);
        }
        40% {
          transform: translateX(6px);
        }
        60% {
          transform: translateX(-4px);
        }
        80% {
          transform: translateX(4px);
        }
        100% {
          transform: translateX(0);
        }
      }

      .option-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
      }

      fieldset {
        margin: 0;
        border: 1px solid var(--line);
        border-radius: 0.75rem;
        padding: 0.9rem 1rem;
      }

      .choices {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 1rem;
        margin-top: 0.5rem;
      }

      .choices label {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--subtle);
        font-size: 0.92rem;
      }

      .actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .note {
        color: var(--subtle);
        font-size: 0.88rem;
      }

      .page-links {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .page-link {
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.92rem;
      }

      .page-link:hover {
        text-decoration: underline;
      }

      .go-button {
        border: 0;
        border-radius: 0.65rem;
        background: var(--accent);
        color: #fff;
        padding: 0.8rem 1.2rem;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
      }

      .go-button:hover {
        background: #0b5f58;
      }

      .field-label-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.65rem;
        flex-wrap: wrap;
      }

      .map-link-button {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        border: 1px solid rgba(15, 118, 110, 0.24);
        background: linear-gradient(135deg, #ecfdf5, #d1fae5);
        color: var(--accent);
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 700;
        line-height: 1;
        box-shadow: 0 4px 12px rgba(15, 118, 110, 0.08);
        transition:
          transform 140ms ease,
          box-shadow 140ms ease,
          background 140ms ease;
      }

      .map-link-button:hover {
        background: linear-gradient(135deg, #dffaf1, #bbf7d0);
        box-shadow: 0 8px 18px rgba(15, 118, 110, 0.14);
        transform: translateY(-1px);
        text-decoration: none;
      }

      .map-link-button:focus-visible {
        outline: 3px solid rgba(15, 118, 110, 0.22);
        outline-offset: 2px;
      }

      .error-toast {
        position: fixed;
        top: 1.25rem;
        right: 1.25rem;
        max-width: min(92vw, 460px);
        background: linear-gradient(140deg, #fff5f5 0%, #ffe8e8 100%);
        border: 1px solid #f8b4b4;
        border-left: 6px solid #dc2626;
        border-radius: 12px;
        box-shadow: 0 14px 30px rgba(127, 29, 29, 0.18);
        padding: 0.95rem 1rem 0.9rem;
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 0.7rem;
        align-items: start;
        opacity: 0;
        transform: translateY(-12px) scale(0.98);
        pointer-events: none;
        transition:
          opacity 180ms ease,
          transform 180ms ease;
        z-index: 999;
      }

      .error-toast.show {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
      }

      .error-toast-icon {
        font-size: 1.05rem;
        line-height: 1.4;
      }

      .error-toast-title {
        margin: 0;
        font-size: 0.95rem;
        font-weight: 700;
        color: #991b1b;
      }

      .error-toast-body {
        margin: 0.2rem 0 0;
        color: #7f1d1d;
        font-size: 0.88rem;
        line-height: 1.35;
      }

      .error-toast-close {
        border: 0;
        background: transparent;
        color: #991b1b;
        font-size: 1.1rem;
        line-height: 1;
        cursor: pointer;
        padding: 0.1rem;
      }

      @media (max-width: 760px) {
        body {
          padding: 1rem;
        }

        .hero {
          padding: 1rem;
        }

        .field-grid,
        .option-grid {
          grid-template-columns: 1fr;
        }

        .actions {
          align-items: stretch;
        }

        .go-button {
          width: 100%;
        }

        .error-toast {
          right: 0.75rem;
          left: 0.75rem;
          max-width: none;
        }
      }
    </style>
  </head>
  <body>
    <aside
      id="addressErrorToast"
      class="error-toast{{#if errorMessage}} show{{/if}}"
      role="alert"
      aria-live="assertive"
      aria-hidden="{{#if errorMessage}}false{{else}}true{{/if}}"
    >
      <div class="error-toast-icon" aria-hidden="true">⚠️</div>
      <div>
        <p class="error-toast-title">
          {{#if errorMessage}}Weather data error{{else}}Form input error{{/if}}
        </p>
        <p id="addressErrorToastText" class="error-toast-body">{{errorMessage}}</p>
      </div>
      <button
        id="addressErrorToastClose"
        class="error-toast-close"
        type="button"
        aria-label="Close error"
      >
        ×
      </button>
    </aside>
    <main class="shell">
      <section class="hero">
        <div class="page-links">
        </div>
        <h1 class="weather-title"><span>Weather Explorer</span></h1>
        <p class="subtitle">
          Choose a location plus a start and end date to view one weather row
          per day across the selected date range.
        </p>

        <form
          class="search-form"
          action="/weather/range"
          method="get"
          novalidate
        >
          <div class="field-grid">
            <div class="field">
              <label for="address" class="field-label-row">
                <span>Address, ZIP, or lat/lon</span>
                <a class="map-link-button" href="/weather/map?returnTo=range-landing">
                  📍 Use map
                </a>
              </label>
              <input
                id="address"
                name="address"
                type="text"
                placeholder="08873, Seattle, WA, or 40.7128, -74.0060"
                title="Enter a street address, city/state, ZIP code, or latitude/longitude"
                value="{{address}}"
                required
              />
            </div>
            <div class="field">
              <label for="startDate">Start date</label>
              <input
                id="startDate"
                name="startDate"
                type="date"
                value="{{defaultStartDate}}"
                max="{{maxDate}}"
                required
              />
            </div>
            <div class="field">
              <label for="endDate">End date</label>
              <input
                id="endDate"
                name="endDate"
                type="date"
                value="{{defaultEndDate}}"
                min="{{defaultStartDate}}"
                max="{{maxDate}}"
                required
              />
            </div>
          </div>

          <div class="option-grid">
            <fieldset>
              <legend class="legend">Temperature</legend>
              <div class="choices">
                <label>
                  <input
                    type="radio"
                    name="temperatureUnit"
                    value="fahrenheit"
                    {{#if isCelsius}}{{else}}checked{{/if}}
                  />
                  Fahrenheit
                </label>
                <label>
                  <input
                    type="radio"
                    name="temperatureUnit"
                    value="celsius"
                    {{#if isCelsius}}checked{{/if}}
                  />
                  Celsius
                </label>
              </div>
            </fieldset>

            <fieldset>
              <legend class="legend">Distance & precipitation</legend>
              <div class="choices">
                <label>
                  <input
                    type="radio"
                    name="unitSystem"
                    value="english"
                    {{#if isMetric}}{{else}}checked{{/if}}
                  />
                  English (in / ft / mph)
                </label>
                <label>
                  <input
                    type="radio"
                    name="unitSystem"
                    value="metric"
                    {{#if isMetric}}checked{{/if}}
                  />
                  Metric (cm / m / km/h)
                </label>
              </div>
            </fieldset>
          </div>

          <div class="actions">
            <div class="note">
              Historic dates are allowed, and forecast dates can be selected up
              to about 15 days ahead.
            </div>
            <button class="go-button" type="submit">Go</button>
          </div>
        </form>
      </section>
    </main>
    <script src="/assets/landing.js" defer></script>
  </body>
</html>