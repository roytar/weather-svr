<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Weather Map Selector</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/leaflet-draw@1.0.4/dist/leaflet.draw.css"
    />
    <style>
      :root {
        color-scheme: light;
        font-family: Inter, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        background: radial-gradient(
          circle at top,
          #eff6ff 0%,
          #f8fbff 45%,
          #f4f7fb 100%
        );
        color: #1f2937;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: transparent;
      }

      .shell {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px 16px 40px;
      }

      .page-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 14px;
        color: #2563eb;
        text-decoration: none;
        font-weight: 700;
      }

      .hero {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(148, 163, 184, 0.28);
        border-radius: 20px;
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
        padding: 24px;
      }

      h1 {
        margin: 0 0 10px;
        font-size: clamp(2rem, 3vw, 2.5rem);
      }

      .subtitle {
        margin: 0 0 18px;
        color: #475569;
        line-height: 1.6;
      }

      .status {
        display: inline-flex;
        align-items: center;
        margin: 0 0 14px;
        padding: 8px 12px;
        border-radius: 999px;
        background: #eff6ff;
        color: #1d4ed8;
        font-size: 0.95rem;
        font-weight: 600;
      }

      .status.error {
        background: #fef2f2;
        color: #b91c1c;
      }

      .map-frame {
        width: 100%;
        height: 560px;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(148, 163, 184, 0.35);
      }

      .selection-pin-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 14px;
        height: 14px;
      }

      .selection-pin-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: #dc2626;
        border: 2px solid #fff;
        box-shadow:
          0 0 0 1px rgba(15, 23, 42, 0.22),
          0 2px 8px rgba(15, 23, 42, 0.18);
      }

      @media (max-width: 640px) {
        .shell {
          padding-inline: 10px;
        }

        .hero {
          padding: 16px;
        }

        .map-frame {
          height: 420px;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <a class="page-link" href="/">← Back to Weather Explorer</a>

      <section class="hero">
        <h1>Weather Explorer Location Selector</h1>
        <p class="subtitle">
          Enable browser to center the map near you. Otherwise USA view is
          shown.<br />
          Drop a pin or draw a rectangle to select a location or region.
        </p>

        <p id="mapStatus" class="status" aria-live="polite">
          Loading map and requesting browser location…
        </p>

        <div
          id="selectionMap"
          class="map-frame"
          aria-label="Interactive map for selecting a rectangle"
        ></div>
      </section>

    </main>

    <script
      src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/leaflet-draw@1.0.4/dist/leaflet.draw.js"
    ></script>
    <script src="/assets/weather-map.js"></script>
  </body>
</html>