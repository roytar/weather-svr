        <script>
		var areaObj = {"home":"Home","region":"Region","regions":"Regions","myfav":"Personalize","wtnew":"What's New","abtus": "About"};
            selector_list += ' ,.system_content';

            // adjust the width of the main content
            function adjustWidth() {
                var w1 = $(".page_pilot_content_bottom").width();
                $(".page_pilot_content2").width(w1 - 20);
                $('.page_pilot_subtitle').width(w1 - 40);
            }

            $(document).ready(function () {
				$('.header-menu-right').css('display','none');
				//site map
					ajax_get_region_info_map('en');
					ajax_get_member_info_sitemap('en');
					generateSiteMap('regions');
				//site map
                $('.social-network-small').html($('.social-network').clone().contents());

                // header slide down menu for tablet and mobile
                $('.header-menu-btn a').click(function () {
                    if ($('.header-menu').is(':visible')) {
                        $('.header-menu').slideUp(500, function () {
                            $('.header-menu-btn a').children('img').attr('src', '../images/arrow_down.png');
                        });
                    } else {
                        $('.header-menu').slideDown(500, function () {
                            $('.header-menu-btn a').children('img').attr('src', '../images/arrow_up.png');
                        });
                    }
                });

                // main slide down menu for tablet and mobile
                $('.main-menu-btn').click(function () {
                    if ($('.mainmenu').is(':visible')) {
                        $('.mainmenu').slideUp(500, function () {});
                    } else {
                        $('.mainmenu').slideDown(500, function () {});
                    }
                });

                // slide up / slide down control
                $('.intro-arrow-btn').click(function () {
                    $intro_arrow_btn = $(this);
                    $page_pilot_content = $(this).parent().prev();
                    $page_pilot_subtitle = $(this).prev();
                    if ($page_pilot_content.is(':visible')) {
                        $page_pilot_subtitle.css('display', 'inline-block');
                        $intro_arrow_btn.css('margin-top', '10px');
                        $page_pilot_content.slideUp(500, function () {
                            $intro_arrow_btn.children('a').children('img').attr('src', '../images/arrow_down.png');
                        });
                    } else {
                        $page_pilot_subtitle.css('display', 'none');
                        $intro_arrow_btn.css('margin-top', '0px');
                        $page_pilot_content.slideDown(500, function () {
                            $intro_arrow_btn.children('a').children('img').attr('src', '../images/arrow_up.png');
                        });
                    }
                    adjustWidth();
                });

                if (isCookieEnabled && getCookie('fontsize_e') != null)
                    changeFontSize(getCookie('fontsize_e'));
                else {
					var fsv = '0';
                    changeFontSize(fsv);
                }

                adjustWidth();
            });

            $(window).resize(function () {
                adjustWidth();
            });

        </script>
    </head>
